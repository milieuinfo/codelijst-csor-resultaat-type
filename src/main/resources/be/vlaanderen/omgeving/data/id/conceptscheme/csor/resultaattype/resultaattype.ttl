<https://data.omgeving.vlaanderen.be/id/conceptscheme/csor/resultaattype>
        rdf:type            skos:ConceptScheme;
        owl:deprecated      false;
        skos:definition     "Het resultaattype beschrijft de wijze waarop het resultaat van een observatie kan worden voorgesteld."@nl;
        skos:hasTopConcept  <https://data.omgeving.vlaanderen.be/id/concept/csor/resultaattype/RT_4> , <https://data.omgeving.vlaanderen.be/id/concept/csor/resultaattype/RT_2> , <https://data.omgeving.vlaanderen.be/id/concept/csor/resultaattype/RT_3> , <https://data.omgeving.vlaanderen.be/id/concept/csor/resultaattype/RT_1>;
        skos:prefLabel      "Resultaattype"@nl .
