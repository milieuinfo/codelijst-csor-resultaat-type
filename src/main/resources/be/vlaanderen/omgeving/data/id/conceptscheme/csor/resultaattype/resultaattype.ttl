<https://data.omgeving.vlaanderen.be/id/concept/csor/resultaattype/RT_1>
        rdf:type           csor:Resultaattype , skos:Concept;
        owl:deprecated     false;
        skos:definition    "Meting toelichting"@nl;
        skos:inScheme      <https://data.omgeving.vlaanderen.be/id/conceptscheme/csor/resultaattype>;
        skos:prefLabel     "Meting"@nl;
        skos:topConceptOf  <https://data.omgeving.vlaanderen.be/id/conceptscheme/csor/resultaattype> .

<https://data.omgeving.vlaanderen.be/id/concept/csor/resultaattype/RT_3>
        rdf:type           csor:Resultaattype , skos:Concept;
        owl:deprecated     false;
        skos:inScheme      <https://data.omgeving.vlaanderen.be/id/conceptscheme/csor/resultaattype>;
